<div id="card-style">
    <div id="card-div">
        <div class="avatar">
            <img src="<%- url_for(theme.avatar) %>" alt="avatar" />
        </div>
        <div class="name"><%= config.author %></div>
        <div class="description">
            <%- markdown(theme.card.description) %>
        </div>
        <% if (theme.card.iconLinks) { %>
        <div class="icon-links">
            <% Object.entries(theme.card.iconLinks).forEach(([key, value]) => { %>
            <span class="icon-link">
                <a href="<%- url_for(value.link) %>">
                    <i
                        class="fa-<%- value.theme %> fa-<%- value.name %> fa-fw"
                    ></i>
                </a>
            </span>
            <% }); %>
        </div>
        <% } %>
        <% if (theme.card.friendLinks) { %>
        <div class="friend-links">
            <% Object.entries(theme.card.friendLinks).forEach(([key, value]) => { %>
            <div class="friend-link">
                <a href="<%- url_for(value) %>"><%= key %></a>
            </div>
            <% }); %>
        </div>
        <% } %>
        <div class="card-section-title">
            <i class="fa-solid fa-bookmark fa-fw"></i>
            分类
        </div>
        <div class="card-categories">
            <% let prevCat; %>
            <% site.categories.forEach((category) => { %>
            <%
                const colors = theme.colors.filter((color) => color !== prevCat);
                let id = Math.floor(Math.random() * colors.length);
                prevCat = colors[id];
            %>
            <a href="<%- url_for(category.path) %>" class="card-category-item" style="background: <%- colors[id] %>">
                <%= category.name %>
                <span class="count"><%= category.posts.length %></span>
            </a>
            <% }); %>
        </div>
        <div class="card-section-title">
            <i class="fa-solid fa-tags fa-fw"></i>
            标签
        </div>
        <div class="card-tags">
            <% let prevTag; %>
            <% site.tags.forEach((tag) => { %>
            <%
                const colors = theme.colors.filter((color) => color !== prevTag);
                let id = Math.floor(Math.random() * colors.length);
                prevTag = colors[id];
            %>
            <a href="<%- url_for(tag.path) %>" class="card-tag-item" style="color: <%- colors[id] %>">
                <i class="fa-solid fa-tag fa-fw"></i>
                <%= tag.name %>
                <span class="count">(<%= tag.posts.length %>)</span>
            </a>
            <% }); %>
        </div>
    </div>
</div>
